# Server Configuration
PORT=3002
NODE_ENV=development

# SMTP Configuration for Email Sending
# Gmail example: smtp.gmail.com:587
# Office365 example: smtp.office365.com:587
# Custom SMTP: your-smtp-server.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Configuration
EMAIL_FROM=3D Clinical <no-reply@3dclinical.com>
EMAIL_TO=info@3dclinical.com
EMAIL_REPLY_TO=support@3dclinical.com

# Note: For Gmail, use App Passwords (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
